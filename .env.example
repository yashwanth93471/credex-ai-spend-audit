# =============================================================================
# Credex — environment variables
# =============================================================================
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# All keys here are validated by Zod in src/lib/env.ts; missing required values
# crash the app at first call (fail-fast).
# =============================================================================

# --- Supabase ---------------------------------------------------------------
# Server-only (writes via service role): Supabase project URL + service key.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Client-safe (RLS-respecting reads from anon role).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- App --------------------------------------------------------------------
# Public absolute URL of the deployed app. Used for OG / canonical links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Anthropic (audit summary generation) -----------------------------------
# Optional on Day 1. Required from Day 3 onward; falls back to a deterministic
# template summary if absent or if the API call fails.
ANTHROPIC_API_KEY=

# --- Resend (transactional email) -------------------------------------------
# Optional on Day 1. Required for emailing the audit report after lead claim.
RESEND_API_KEY=
RESEND_FROM_EMAIL=audits@credex.example
